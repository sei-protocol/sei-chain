// Data-dependent: createAccessList with EIP1559 options for our deployed contract. Run evm_rpc_tests.sh when local.
// Geth's AccessList path runs setFeeDefaults: if both maxFeePerGas and maxPriorityFeePerGas are set, maxFeePerGas must
// be non-zero (eth_call/DoCall only uses CallDefaults, so zero caps are allowed there). Non-zero caps also require
// BuyGas balance >= gasLimit*maxFeePerGas, so use the deploy tx sender (from receipt) as "from".
>> {"jsonrpc":"2.0","id":1,"method":"eth_getBlockByNumber","params":["__SEED__",true]}
<< {"jsonrpc":"2.0","id":1,"result":{}}
@ bind deployTxHash = result.transactions.1.hash
>> {"jsonrpc":"2.0","id":1,"method":"eth_getTransactionReceipt","params":["${deployTxHash}"]}
<< {"jsonrpc":"2.0","id":1,"result":{}}
@ bind contractAddress = result.contractAddress
@ bind deployerFrom = result.from
>> {"jsonrpc":"2.0","id":1,"method":"eth_createAccessList","params":[{"from":"${deployerFrom}","to":"${contractAddress}","data":"0x","maxFeePerGas":"0x174876e800","maxPriorityFeePerGas":"0x3b9aca00"},"__SEED__"]}
<< {"jsonrpc":"2.0","id":1,"result":{}}
