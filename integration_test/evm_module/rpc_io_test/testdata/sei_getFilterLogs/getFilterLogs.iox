// Data-dependent: sei_newFilter, bind filterId, then sei_getFilterLogs(filterId). Run evm_rpc_tests.sh when local.
// Use latest->latest so block span stays within max_blocks_for_log (default 2000); 0x1->latest fails on long-lived localnet.
>> {"jsonrpc":"2.0","id":1,"method":"sei_newFilter","params":[{"fromBlock":"latest","toBlock":"latest"}]}
<< {"jsonrpc":"2.0","id":1,"result":"0x"}
@ bind filterId = result
>> {"jsonrpc":"2.0","id":2,"method":"sei_getFilterLogs","params":["${filterId}"]}
<< {"jsonrpc":"2.0","id":2,"result":[]}
