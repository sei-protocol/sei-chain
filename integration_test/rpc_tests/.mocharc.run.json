{
    "require": ["tsx"],
    "timeout": 600000,
    "exit": true,
    "reporter": "mochawesome",
    "reporter-option": [
        "reportDir=reports/new_rpc",
        "reportFilename=run",
        "html=false",
        "json=true",
        "overwrite=true"
    ],
    "spec": [
        "debug/*.spec.ts",
        "echo/*.spec.ts",
        "eth/*.spec.ts",
        "net/*.spec.ts",
        "web3/*.spec.ts"
    ]
}
