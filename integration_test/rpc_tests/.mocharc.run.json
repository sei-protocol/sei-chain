{
    "require": ["tsx"],
    "timeout": 600000,
    "exit": true,
    "reporter": "mochawesome",
    "reporter-option": [
        "reportDir=reports/new_rpc",
        "reportFilename=run",
        "html=false",
        "json=true",
        "overwrite=true"
    ],
    "spec": ["**/*.spec.ts"],
    "ignore": ["_start/*.spec.ts", "node_modules/**"]
}
