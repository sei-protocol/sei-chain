{
  "Comment": "For receipt-read-focused benchmarking against the parquet receipt store with the Pebble tx-hash index enabled. Log-filter reads are disabled to avoid competing with receipt reads.",
  "DisableTransactionExecution": true,
  "DataDir": "data",
  "LogDir": "logs",
  "LogLevel": "info",
  "MinimumNumberOfColdAccounts": 1000000,
  "MinimumNumberOfDormantAccounts": 1000000,
  "GenerateReceipts": true,
  "ReceiptReadConcurrency": 16,
  "ReceiptReadsPerSecond": 500000,
  "ReceiptReadMode": "cache",
  "ReceiptKeepRecent": 100000,
  "ReceiptPruneIntervalSeconds": 60,
  "ReceiptLogFilterReadConcurrency": 0,
  "ReceiptLogFilterReadsPerSecond": 0,
  "ReceiptLogFilterReadMode": "cache",
  "ReceiptLogFilterMinBlockRange": 1,
  "ReceiptLogFilterMaxBlockRange": 10
}
