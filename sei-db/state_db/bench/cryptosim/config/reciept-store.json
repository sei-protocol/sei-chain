{
    "Comment": "For maximizing receipt-read throughput against the parquet receipt store with tx-index lookup disabled. Log-filter reads are disabled to avoid competing with receipt reads.",
    "DisableTransactionExecution": true,
    "BlocksPerCommit": 128,
    "DataDir": "data",
    "LogDir": "logs",
    "LogLevel": "info",
    "MinimumNumberOfColdAccounts": 1000000,
    "MinimumNumberOfDormantAccounts": 1000000,
    "GenerateReceipts": true,
    "ReceiptReadConcurrency": 64,
    "ReceiptReadsPerSecond": 100000,
    "ReceiptReadMode": "duckdb",
    "DisableReceiptTxIndexLookup": true,
    "ReceiptLogFilterReadConcurrency": 0,
    "ReceiptLogFilterReadsPerSecond": 0,
    "ReceiptLogFilterReadMode": "duckdb",
    "ReceiptLogFilterMinBlockRange": 1,
    "ReceiptLogFilterMaxBlockRange": 10
}
